// Prisma Schema for ScoutTN
// Using SQLite for local development (easy switch to PostgreSQL for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER - Base account for all roles
// ============================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("PLAYER") // PLAYER, SCOUT, ACADEMY, CLUB, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  playerProfile PlayerProfile?
  scoutProfile  ScoutProfile?
  favorites     Favorite[]      @relation("ScoutFavorites")
  sentTrials    TrialRequest[]  @relation("TrialSender")
}

// ============================================
// PLAYER PROFILE - Football CV
// ============================================
model PlayerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  firstName     String
  lastName      String
  dateOfBirth   String?
  phone         String?
  city          String?
  region        String?  // Gouvernorat
  nationality   String   @default("Tunisienne")
  height        Int?     // in cm
  weight        Int?     // in kg
  position      String?  // GK, CB, LB, RB, CDM, CM, CAM, LW, RW, ST
  preferredFoot String?  // Left, Right, Both
  currentClub   String?
  avatar        String?  // URL or local path
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stats     PlayerStats?
  videos    Video[]
  favoredBy Favorite[]    @relation("FavoritedPlayer")
  trials    TrialRequest[] @relation("TrialPlayer")
}

// ============================================
// PLAYER STATS - Performance metrics
// ============================================
model PlayerStats {
  id        String @id @default(uuid())
  profileId String @unique

  // Stats out of 100
  speed      Int @default(50)
  technique  Int @default(50)
  endurance  Int @default(50)
  passing    Int @default(50)
  shooting   Int @default(50)
  dribbling  Int @default(50)
  defending  Int @default(50)
  physical   Int @default(50)

  // Match stats
  matchesPlayed Int @default(0)
  goals         Int @default(0)
  assists       Int @default(0)

  updatedAt DateTime @updatedAt

  // Relations
  profile PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ============================================
// SCOUT / CLUB / ACADEMY PROFILE
// ============================================
model ScoutProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  name           String  // Name of scout / club / academy
  organization   String? // Organization name
  city           String?
  region         String?
  phone          String?
  avatar         String?
  bio            String?
  verified       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// VIDEO - Player highlight videos
// ============================================
model Video {
  id           String   @id @default(uuid())
  playerId     String
  title        String
  description  String?
  videoUrl     String   // Local path or Cloudinary URL
  thumbnailUrl String?
  category     String   @default("HIGHLIGHT") // HIGHLIGHT, MATCH, TRAINING, SKILLS
  duration     Int?     // in seconds
  createdAt    DateTime @default(now())

  // Relations
  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

// ============================================
// FAVORITE - Scout's saved players
// ============================================
model Favorite {
  id        String   @id @default(uuid())
  scoutId   String
  playerId  String
  createdAt DateTime @default(now())

  // Relations
  scout  User          @relation("ScoutFavorites", fields: [scoutId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation("FavoritedPlayer", fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([scoutId, playerId])
}

// ============================================
// TRIAL REQUEST - Request to try a player
// ============================================
model TrialRequest {
  id        String   @id @default(uuid())
  fromId    String   // Scout/Club/Academy user ID
  playerId  String   // Player profile ID
  message   String?
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  from   User          @relation("TrialSender", fields: [fromId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation("TrialPlayer", fields: [playerId], references: [id], onDelete: Cascade)
}
